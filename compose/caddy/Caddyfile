{
  admin off
  auto_https off
}

:8080 {
  bind 0.0.0.0
  encode zstd gzip

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy no-referrer
    X-Frame-Options DENY
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self'; script-src 'self'; connect-src 'self'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'"
  }

  handle /healthz {
    respond "ok" 200
  }

  import /etc/nutsnews/caddy/app.routes

  handle /data/* {
    header Cache-Control "no-store"
    root * /srv/nutsnews-portal
    file_server
  }

  handle {
    header Cache-Control "no-store"
    root * /srv/nutsnews-portal
    try_files {path} /index.html
    file_server
  }
}
