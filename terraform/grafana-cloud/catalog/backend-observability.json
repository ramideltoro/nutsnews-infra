{
  "folder": {
    "title": "NutsNews Backend Ops",
    "uid": "nutsnews-backend-ops"
  },
  "guardrails": {
    "max_dashboards": 13,
    "max_panels_per_dashboard": 12,
    "max_total_panels": 80,
    "max_unique_queries": 130,
    "max_alert_rules": 12
  },
  "alert_group": {
    "name": "NutsNews Backend Guardrails",
    "interval_seconds": 60
  },
  "dashboards": [
    {
      "title": "NutsNews Backend Host Overview",
      "uid": "nutsnews-backend-host",
      "panels": [
        {"title": "CPU Busy", "unit": "percentunit", "expr": "1 - avg(rate(node_cpu_seconds_total{job=\"nutsnews-backend-host\",mode=\"idle\"}[5m]))"},
        {"title": "Load Per CPU", "unit": "short", "expr": "node_load1{job=\"nutsnews-backend-host\"} / count(count by (cpu) (node_cpu_seconds_total{job=\"nutsnews-backend-host\",mode=\"idle\"}))"},
        {"title": "Memory Used", "unit": "percentunit", "expr": "1 - (node_memory_MemAvailable_bytes{job=\"nutsnews-backend-host\"} / node_memory_MemTotal_bytes{job=\"nutsnews-backend-host\"})"},
        {"title": "Swap Used", "unit": "percentunit", "expr": "1 - (node_memory_SwapFree_bytes{job=\"nutsnews-backend-host\"} / node_memory_SwapTotal_bytes{job=\"nutsnews-backend-host\"})"},
        {"title": "Root Disk Used", "unit": "percentunit", "expr": "1 - (node_filesystem_avail_bytes{job=\"nutsnews-backend-host\",mountpoint=\"/\",fstype!=\"\"} / node_filesystem_size_bytes{job=\"nutsnews-backend-host\",mountpoint=\"/\",fstype!=\"\"})"},
        {"title": "Root Inodes Used", "unit": "percentunit", "expr": "1 - (node_filesystem_files_free{job=\"nutsnews-backend-host\",mountpoint=\"/\"} / node_filesystem_files{job=\"nutsnews-backend-host\",mountpoint=\"/\"})"},
        {"title": "Network Receive", "unit": "Bps", "expr": "sum by (device) (rate(node_network_receive_bytes_total{job=\"nutsnews-backend-host\",device!~\"lo|veth.*|docker.*\"}[5m]))"},
        {"title": "Network Transmit", "unit": "Bps", "expr": "sum by (device) (rate(node_network_transmit_bytes_total{job=\"nutsnews-backend-host\",device!~\"lo|veth.*|docker.*\"}[5m]))"}
      ]
    },
    {
      "title": "NutsNews Backend Docker and Runtime",
      "uid": "nutsnews-backend-docker-runtime",
      "panels": [
        {"title": "Docker Service Active", "unit": "short", "expr": "nutsnews_backend_service_active{job=\"nutsnews-backend-host\",unit=\"docker\"}"},
        {"title": "Containerd Service Active", "unit": "short", "expr": "node_systemd_unit_state{job=\"nutsnews-backend-host\",name=\"containerd.service\",state=\"active\"}"},
        {"title": "Backend Units", "unit": "short", "expr": "node_systemd_unit_state{job=\"nutsnews-backend-host\",name=~\"nutsnews-.+\",state=\"active\"}"},
        {"title": "Unit Restarts", "unit": "short", "expr": "increase(node_systemd_service_restart_total{job=\"nutsnews-backend-host\",name=~\"docker.service|containerd.service|nutsnews-.+\"}[24h])"}
      ]
    },
    {
      "title": "NutsNews Backend Caddy and Edge",
      "uid": "nutsnews-backend-caddy-edge",
      "panels": [
        {"title": "Caddy Active", "unit": "short", "expr": "nutsnews_backend_service_active{job=\"nutsnews-backend-host\",unit=\"caddy\"}"},
        {"title": "Public Endpoint Healthy", "unit": "short", "expr": "nutsnews_backend_public_endpoint_healthy{job=\"nutsnews-backend-host\"}"},
        {"title": "HTTP/HTTPS Listeners", "unit": "short", "expr": "node_netstat_Tcp_CurrEstab{job=\"nutsnews-backend-host\"}"},
        {"title": "Failed Units", "unit": "short", "expr": "nutsnews_backend_failed_systemd_units{job=\"nutsnews-backend-host\"}"}
      ]
    },
    {
      "title": "NutsNews Backend Service Health",
      "uid": "nutsnews-backend-service-health",
      "panels": [
        {"title": "Core Service Active", "unit": "short", "expr": "nutsnews_backend_service_active{job=\"nutsnews-backend-host\",unit=~\"ssh|ufw|fail2ban|caddy|alloy|sysstat\"}"},
        {"title": "NutsNews Timers Active", "unit": "short", "expr": "nutsnews_backend_service_active{job=\"nutsnews-backend-host\",unit=~\"nutsnews-.+timer\"}"},
        {"title": "Systemd Active State", "unit": "short", "expr": "node_systemd_unit_state{job=\"nutsnews-backend-host\",name=~\"ssh.service|ufw.service|fail2ban.service|caddy.service|alloy.service|sysstat.service|nutsnews-.+\",state=\"active\"}"},
        {"title": "Host Up", "unit": "short", "expr": "up{job=\"nutsnews-backend-host\"}"}
      ]
    },
    {
      "title": "NutsNews Backend Backups",
      "uid": "nutsnews-backend-backups",
      "panels": [
        {"title": "Backup Stage Healthy", "unit": "short", "expr": "nutsnews_backend_backup_stage_healthy{job=\"nutsnews-backend-host\"}"},
        {"title": "Latest Snapshot Verified", "unit": "short", "expr": "nutsnews_backend_backup_latest_snapshot_verified{job=\"nutsnews-backend-host\"}"},
        {"title": "Backup Storage Quota Configured", "unit": "short", "expr": "nutsnews_backend_backup_storage_quota_configured{job=\"nutsnews-backend-host\"}"},
        {"title": "Backup Timers Active", "unit": "short", "expr": "nutsnews_backend_service_active{job=\"nutsnews-backend-host\",unit=~\"nutsnews-backup.*timer|nutsnews-restore-drill.timer\"}"}
      ]
    },
    {
      "title": "NutsNews Backend PostgreSQL Failover",
      "uid": "nutsnews-backend-postgres-failover",
      "importExisting": false,
      "missingRemoteObjectReason": "Grafana Cloud Apply run 29984664724 reported this dashboard UID does not exist remotely, so OpenTofu creates it from the source catalog instead of importing it.",
      "panels": [
        {"title": "PostgreSQL Service Active", "unit": "short", "expr": "nutsnews_backend_service_active{job=\"nutsnews-backend-host\",unit=\"postgresql\"}"},
        {"title": "Failover Restore Ready", "unit": "short", "expr": "nutsnews_backend_postgres_failover_ready{job=\"nutsnews-backend-host\"}"},
        {"title": "Restore Drill Healthy", "unit": "short", "expr": "nutsnews_backend_postgres_restore_drill_healthy{job=\"nutsnews-backend-host\"}"},
        {"title": "Replication Lag Configured", "unit": "short", "expr": "nutsnews_backend_postgres_replication_lag_configured{job=\"nutsnews-backend-host\"}"}
      ]
    },
    {
      "title": "NutsNews Backend OS Updates",
      "uid": "nutsnews-backend-os-updates",
      "panels": [
        {"title": "Reboot Required", "unit": "short", "expr": "nutsnews_backend_reboot_required{job=\"nutsnews-backend-host\"}"},
        {"title": "Upgradable Packages", "unit": "short", "expr": "nutsnews_backend_upgradable_packages{job=\"nutsnews-backend-host\"}"},
        {"title": "Boot Time", "unit": "dateTimeAsIso", "expr": "node_boot_time_seconds{job=\"nutsnews-backend-host\"}"},
        {"title": "Uptime", "unit": "s", "expr": "time() - node_boot_time_seconds{job=\"nutsnews-backend-host\"}"}
      ]
    },
    {
      "title": "NutsNews Backend Metrics Quota",
      "uid": "nutsnews-backend-metrics-quota",
      "panels": [
        {"title": "Series Count By Metric", "unit": "short", "expr": "topk(20, count by (__name__) ({job=\"nutsnews-backend-host\"}))"},
        {"title": "Unique Metric Names", "unit": "short", "expr": "count(count by (__name__) ({job=\"nutsnews-backend-host\"}))"},
        {"title": "Alloy Remote Write Pending Samples", "unit": "short", "expr": "prometheus_remote_storage_samples_pending{job=\"nutsnews-backend-host\"}"},
        {"title": "Alloy Remote Write Failed Samples", "unit": "short", "expr": "increase(prometheus_remote_storage_samples_failed_total{job=\"nutsnews-backend-host\"}[1h])"}
      ]
    },
    {
      "title": "NutsNews Backend Alert and Synthetic Health",
      "uid": "nutsnews-backend-alert-synthetic",
      "panels": [
        {"title": "Grafana Alert State", "unit": "short", "expr": "ALERTS{alertname=~\"NutsNews.*\"}"},
        {"title": "Synthetic Probe Success", "unit": "short", "expr": "probe_success{job=~\".*nutsnews.*|.*backend.*\"}"},
        {"title": "Synthetic Probe Duration", "unit": "s", "expr": "probe_duration_seconds{job=~\".*nutsnews.*|.*backend.*\"}"},
        {"title": "Missing Backend Metrics", "unit": "short", "expr": "absent(up{job=\"nutsnews-backend-host\"})"}
      ]
    },
    {
      "title": "NutsNews Backend Logs",
      "uid": "nutsnews-backend-logs",
      "panels": [
        {"title": "Recent Systemd Journal Logs", "datasource": "loki", "type": "logs", "expr": "{host=\"backend.nutsnews.com\",source=\"journal\"}"},
        {"title": "Log Volume By Service", "datasource": "loki", "unit": "short", "expr": "sum by (service) (count_over_time({host=\"backend.nutsnews.com\"}[15m]))"},
        {"title": "Warnings And Errors", "datasource": "loki", "type": "logs", "expr": "{host=\"backend.nutsnews.com\",severity=~\"warning|error|crit|alert|emerg\"}"},
        {"title": "Security Logs", "datasource": "loki", "type": "logs", "expr": "{host=\"backend.nutsnews.com\",service=\"security\"}"},
        {"title": "SSH Auth Failure Volume", "datasource": "loki", "unit": "short", "expr": "sum(count_over_time({host=\"backend.nutsnews.com\",service=\"security\"} |~ \"(?i)(failed password|invalid user|authentication failure|maximum authentication attempts)\" [15m]))"},
        {"title": "Fail2ban Ban Events", "datasource": "loki", "unit": "short", "expr": "sum(count_over_time({host=\"backend.nutsnews.com\",service=\"security\"} |~ \"(?i)(notice.*\\bban\\b|sshd.*\\bban\\b)\" [15m]))"},
        {"title": "Backup And Timer Logs", "datasource": "loki", "type": "logs", "expr": "{host=\"backend.nutsnews.com\",service=~\"backup|timer\"}"},
        {"title": "Log Volume By Source", "datasource": "loki", "unit": "short", "expr": "sum by (source) (count_over_time({host=\"backend.nutsnews.com\"}[15m]))"}
      ]
    },
    {
      "title": "NutsNews Worker-Uplift RabbitMQ Overview",
      "uid": "nutsnews-worker-uplift-rabbitmq-overview",
      "description": "Broker health, stage flow, backlog, DLQ, telemetry freshness, alarms, and Alloy health for the worker-uplift RabbitMQ path.",
      "importExisting": false,
      "missingRemoteObjectReason": "New source-controlled dashboard for ramideltoro/nutsnews-worker#89; OpenTofu creates it after the #141 Grafana ownership handoff.",
      "panels": [
        {"title": "Broker Scrape Up", "type": "stat", "unit": "short", "description": "RabbitMQ aggregate scrape health from the backend Alloy collector.", "expr": "max(up{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"})", "links": [{"title": "Filtered RabbitMQ logs", "targetBlank": false, "url": "/explore?left=%7B%22datasource%22%3A%22%24%24%7Bloki_datasource_uid%7D%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22datasource%22%3A%7B%22type%22%3A%22loki%22%2C%22uid%22%3A%22%24%24%7Bloki_datasource_uid%7D%22%7D%2C%22expr%22%3A%22%7Bhost%3D~%5C%22%24host%5C%22%2Csource%3D%5C%22container%5C%22%2Cservice%3D%5C%22rabbitmq%5C%22%7D%22%2C%22queryType%22%3A%22range%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-6h%22%2C%22to%22%3A%22now%22%7D%7D"}]},
        {"title": "Queue Metrics Scrape Up", "type": "stat", "unit": "short", "description": "Detailed queue scrape health for the declared worker-uplift queues.", "expr": "max(up{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\"})"},
        {"title": "Ready Messages Total", "type": "stat", "unit": "short", "description": "Ready backlog across selected worker-uplift queues.", "expr": "sum(rabbitmq_detailed_queue_messages_ready{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"$queue\"})"},
        {"title": "Unacked Messages Total", "type": "stat", "unit": "short", "description": "In-flight messages that have been delivered but not acknowledged.", "expr": "sum(rabbitmq_detailed_queue_messages_unacked{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"$queue\"})"},
        {"title": "Ingress Publish Rate", "unit": "ops", "description": "Aggregate RabbitMQ publish rate when the broker exposes publish counters.", "expr": "sum(rate(rabbitmq_queue_messages_published_total{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"}[$__rate_interval]))"},
        {"title": "Egress Ack Rate", "unit": "ops", "description": "Acknowledgement throughput across selected worker-uplift queues.", "expr": "sum(rate(rabbitmq_detailed_queue_messages_acked_total{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"$queue\"}[$__rate_interval]))"},
        {"title": "Redelivery Rate", "unit": "ops", "description": "Message redelivery rate across selected worker-uplift queues.", "expr": "sum(rate(rabbitmq_detailed_queue_messages_redelivered_total{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"$queue\"}[$__rate_interval]))"},
        {"title": "DLQ Ready Messages", "type": "stat", "unit": "short", "description": "Ready messages parked in terminal worker-uplift DLQs.", "expr": "sum(rabbitmq_detailed_queue_messages_ready{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\".*\\.dlq$\"})"},
        {"title": "Stage Ack Throughput", "unit": "ops", "description": "Acknowledgement throughput grouped by selected main-stage queue.", "expr": "sum by (queue) (rate(rabbitmq_detailed_queue_messages_acked_total{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"nutsnews\\.worker\\.($stage)\\.v1\"}[$__rate_interval]))"},
        {"title": "Queue Metric Freshness", "type": "stat", "unit": "s", "description": "Age of the newest detailed queue metric sample; worker-owned oldest-content age metrics are expected later.", "expr": "max(time() - timestamp(rabbitmq_detailed_queue_messages{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"$queue\"}))"},
        {"title": "Broker Alarms", "type": "stat", "unit": "short", "description": "RabbitMQ memory, disk, and general alarm signals when exposed by the broker exporter.", "expr": "max(rabbitmq_alarms{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"} or rabbitmq_alarms_memory_used_watermark{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"} or rabbitmq_alarms_free_disk_space_watermark{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"})"},
        {"title": "Alloy Remote Write Pending Samples", "type": "stat", "unit": "short", "description": "Backend Alloy remote-write backlog; sustained nonzero values can mean telemetry is not leaving the host.", "expr": "max(prometheus_remote_storage_samples_pending{job=\"nutsnews-backend-host\",instance=~\"$host\"})"}
      ]
    },
    {
      "title": "NutsNews Worker-Uplift Queue Drilldown",
      "uid": "nutsnews-worker-uplift-rabbitmq-queues",
      "description": "Queue and stage drill-down for depth, consumer pressure, retries, DLQs, delivery/ack rates, service versions, and filtered Loki logs.",
      "importExisting": false,
      "missingRemoteObjectReason": "New source-controlled dashboard for ramideltoro/nutsnews-worker#89; OpenTofu creates it after the #141 Grafana ownership handoff.",
      "panels": [
        {"title": "Selected Queue Depth", "unit": "short", "description": "Total messages in every selected queue.", "expr": "sum by (queue) (rabbitmq_detailed_queue_messages{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"$queue\"})", "links": [{"title": "Filtered queue logs", "targetBlank": false, "url": "/explore?left=%7B%22datasource%22%3A%22%24%24%7Bloki_datasource_uid%7D%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22datasource%22%3A%7B%22type%22%3A%22loki%22%2C%22uid%22%3A%22%24%24%7Bloki_datasource_uid%7D%22%7D%2C%22expr%22%3A%22%7Bhost%3D~%5C%22%24host%5C%22%2Csource%3D%5C%22container%5C%22%2Cqueue%3D~%5C%22%24queue%5C%22%7D%22%2C%22queryType%22%3A%22range%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-6h%22%2C%22to%22%3A%22now%22%7D%7D"}]},
        {"title": "Ready By Queue", "unit": "short", "description": "Messages ready for delivery by selected queue.", "expr": "sum by (queue) (rabbitmq_detailed_queue_messages_ready{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"$queue\"})"},
        {"title": "Unacked By Queue", "unit": "short", "description": "Delivered but unacknowledged messages by selected queue.", "expr": "sum by (queue) (rabbitmq_detailed_queue_messages_unacked{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"$queue\"})"},
        {"title": "Consumer Count By Queue", "unit": "short", "description": "Consumer count by selected queue.", "expr": "sum by (queue) (rabbitmq_detailed_queue_consumers{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"$queue\"})"},
        {"title": "Consumer Utilisation By Queue", "unit": "percentunit", "description": "RabbitMQ consumer utilisation by selected queue.", "expr": "avg by (queue) (rabbitmq_detailed_queue_consumer_utilisation{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"$queue\"})"},
        {"title": "Consumer Capacity By Queue", "unit": "percentunit", "description": "RabbitMQ consumer capacity by selected queue.", "expr": "avg by (queue) (rabbitmq_detailed_queue_consumer_capacity{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"$queue\"})"},
        {"title": "Deliver Rate By Queue", "unit": "ops", "description": "Delivered message rate by selected queue.", "expr": "sum by (queue) (rate(rabbitmq_detailed_queue_messages_delivered_total{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"$queue\"}[$__rate_interval]))"},
        {"title": "Ack Rate By Queue", "unit": "ops", "description": "Acknowledgement rate by selected queue.", "expr": "sum by (queue) (rate(rabbitmq_detailed_queue_messages_acked_total{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\"$queue\"}[$__rate_interval]))"},
        {"title": "Retry Queue Depth", "unit": "short", "description": "Backlog in selected retry queues.", "expr": "sum by (queue) (rabbitmq_detailed_queue_messages_ready{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\".*\\.retry-(30s|5m|30m)$\"})"},
        {"title": "DLQ Queue Depth", "unit": "short", "description": "Backlog in selected terminal DLQs.", "expr": "sum by (queue) (rabbitmq_detailed_queue_messages_ready{job=\"nutsnews-rabbitmq-queues\",environment=~\"$environment\",host=~\"$host\",vhost=~\"$vhost\",queue=~\".*\\.dlq$\"})"},
        {"title": "Worker Service Versions And Logs", "datasource": "loki", "type": "logs", "description": "Structured worker-uplift logs filtered by selected host, service, and queue; worker services can be empty until deployment.", "expr": "{host=~\"$host\",source=\"container\",service=~\"$service\",queue=~\"$queue\"}"}
      ]
    },
    {
      "title": "NutsNews Worker-Uplift RabbitMQ Resources",
      "uid": "nutsnews-worker-uplift-rmq-resources",
      "description": "RabbitMQ node resources, connections, channels, consumers, queue count, file descriptors, and resource-related logs.",
      "importExisting": false,
      "missingRemoteObjectReason": "New source-controlled dashboard for ramideltoro/nutsnews-worker#89; OpenTofu creates it after the #141 Grafana ownership handoff.",
      "panels": [
        {"title": "RabbitMQ Connections", "unit": "short", "description": "Open RabbitMQ connections.", "expr": "sum(rabbitmq_connections{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"})"},
        {"title": "RabbitMQ Channels", "unit": "short", "description": "Open RabbitMQ channels.", "expr": "sum(rabbitmq_channels{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"})"},
        {"title": "RabbitMQ Consumers", "unit": "short", "description": "Total RabbitMQ consumers.", "expr": "sum(rabbitmq_consumers{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"})"},
        {"title": "RabbitMQ Queue Count", "unit": "short", "description": "Queue count visible from the aggregate RabbitMQ exporter.", "expr": "sum(rabbitmq_queues{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"})"},
        {"title": "RabbitMQ Memory Used", "unit": "bytes", "description": "RabbitMQ process or node memory used when exposed by the exporter.", "expr": "max(rabbitmq_process_resident_memory_bytes{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"} or rabbitmq_node_mem_used{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"})"},
        {"title": "RabbitMQ Disk Free", "unit": "bytes", "description": "RabbitMQ free disk signal when exposed by the exporter.", "expr": "min(rabbitmq_node_disk_free{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"} or rabbitmq_disk_space_available_bytes{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"})"},
        {"title": "RabbitMQ File Descriptor Usage", "unit": "percentunit", "description": "RabbitMQ file descriptor usage ratio when open/max file descriptor gauges are exposed.", "expr": "max(rabbitmq_process_open_fds{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"} / rabbitmq_process_max_fds{job=\"nutsnews-rabbitmq\",environment=~\"$environment\",host=~\"$host\"})"},
        {"title": "RabbitMQ Resource Logs", "datasource": "loki", "type": "logs", "description": "RabbitMQ logs filtered for resource, connection, channel, and alarm terms.", "expr": "{host=~\"$host\",source=\"container\",service=\"rabbitmq\"} |~ \"(?i)(memory|disk|alarm|connection|channel|file descriptor)\""}
      ]
    }
  ],
  "alerts": [
    {
      "uid": "nutsnews-backend-host-metrics-missing",
      "title": "NutsNews backend host metrics missing",
      "severity": "critical",
      "service": "alloy",
      "expr": "absent(up{job=\"nutsnews-backend-host\"})",
      "threshold": 0,
      "evaluator": "gt",
      "for": "5m",
      "range_seconds": 600,
      "no_data_state": "OK",
      "summary": "Grafana Cloud is not receiving backend host metrics from Alloy."
    },
    {
      "uid": "nn-backend-endpoint-unhealthy",
      "title": "NutsNews backend public endpoint unhealthy",
      "severity": "critical",
      "service": "caddy",
      "expr": "min_over_time(nutsnews_backend_public_endpoint_healthy{job=\"nutsnews-backend-host\"}[5m])",
      "threshold": 1,
      "evaluator": "lt",
      "for": "5m",
      "range_seconds": 600,
      "no_data_state": "OK",
      "summary": "The backend /healthz endpoint is failing from the host probe."
    },
    {
      "uid": "nn-backend-failed-units",
      "title": "NutsNews backend failed systemd units",
      "severity": "critical",
      "service": "systemd",
      "expr": "nutsnews_backend_failed_systemd_units{job=\"nutsnews-backend-host\"}",
      "threshold": 0,
      "evaluator": "gt",
      "for": "2m",
      "range_seconds": 600,
      "no_data_state": "OK",
      "summary": "One or more backend systemd units are failed."
    },
    {
      "uid": "nn-backend-backup-unhealthy",
      "title": "NutsNews backend backup or restore coverage unhealthy",
      "severity": "critical",
      "service": "backup",
      "expr": "min(nutsnews_backend_backup_stage_healthy{job=\"nutsnews-backend-host\"})",
      "threshold": 1,
      "evaluator": "lt",
      "for": "15m",
      "range_seconds": 1800,
      "no_data_state": "OK",
      "summary": "A backend backup, verification, or restore-drill stage is unhealthy."
    },
    {
      "uid": "nn-backend-postgres-restore-not-ready",
      "title": "NutsNews backend PostgreSQL restore drill not ready",
      "severity": "warning",
      "service": "postgresql",
      "expr": "nutsnews_backend_postgres_failover_ready{job=\"nutsnews-backend-host\"}",
      "threshold": 1,
      "evaluator": "lt",
      "for": "30m",
      "range_seconds": 3600,
      "no_data_state": "OK",
      "summary": "The private PostgreSQL failover target does not have a healthy restore drill."
    },
    {
      "uid": "nn-backend-root-disk-warning",
      "title": "NutsNews backend root disk warning",
      "severity": "warning",
      "service": "host",
      "expr": "1 - (node_filesystem_avail_bytes{job=\"nutsnews-backend-host\",mountpoint=\"/\",fstype!=\"\"} / node_filesystem_size_bytes{job=\"nutsnews-backend-host\",mountpoint=\"/\",fstype!=\"\"})",
      "threshold": 0.8,
      "evaluator": "gt",
      "for": "15m",
      "range_seconds": 1800,
      "no_data_state": "OK",
      "summary": "Backend root filesystem usage is above the warning threshold."
    },
    {
      "uid": "nn-backend-reboot-required",
      "title": "NutsNews backend reboot required outside maintenance",
      "severity": "warning",
      "service": "updates",
      "expr": "nutsnews_backend_reboot_required{job=\"nutsnews-backend-host\"}",
      "threshold": 0,
      "evaluator": "gt",
      "for": "24h",
      "range_seconds": 86400,
      "no_data_state": "OK",
      "summary": "The backend host has needed a reboot for more than one day."
    },
    {
      "uid": "nn-backend-journal-logs-missing",
      "title": "NutsNews backend journal logs missing in Loki",
      "severity": "warning",
      "service": "alloy",
      "datasource": "loki",
      "expr": "sum(count_over_time({host=\"backend.nutsnews.com\",source=\"journal\"}[2h]))",
      "threshold": 1,
      "evaluator": "lt",
      "for": "15m",
      "range_seconds": 7200,
      "no_data_state": "Alerting",
      "summary": "Grafana Cloud Loki is not receiving backend journal logs."
    },
    {
      "uid": "nn-backend-ssh-auth-spike",
      "title": "NutsNews backend SSH auth failure spike",
      "severity": "warning",
      "service": "security",
      "datasource": "loki",
      "expr": "sum(count_over_time({host=\"backend.nutsnews.com\",service=\"security\"} |~ \"(?i)(failed password|invalid user|authentication failure|maximum authentication attempts)\" [15m]))",
      "threshold": 25,
      "evaluator": "gt",
      "for": "5m",
      "range_seconds": 1800,
      "no_data_state": "OK",
      "runbook_url": "https://github.com/ramideltoro/nutsnews-backend/blob/main/runbooks/ABUSE_PROTECTION.md",
      "summary": "SSH authentication failures are above the detection threshold. This is report-only and does not add new blocking."
    },
    {
      "uid": "nn-backend-fail2ban-ban-events",
      "title": "NutsNews backend fail2ban ban events",
      "severity": "warning",
      "service": "security",
      "datasource": "loki",
      "expr": "sum(count_over_time({host=\"backend.nutsnews.com\",service=\"security\"} |~ \"(?i)(notice.*\\bban\\b|sshd.*\\bban\\b)\" [15m]))",
      "threshold": 0,
      "evaluator": "gt",
      "for": "5m",
      "range_seconds": 1800,
      "no_data_state": "OK",
      "runbook_url": "https://github.com/ramideltoro/nutsnews-backend/blob/main/runbooks/ABUSE_PROTECTION.md",
      "summary": "Fail2ban reported one or more SSH ban events. This surfaces existing SSH enforcement activity without changing enforcement."
    },
    {
      "uid": "nn-backend-log-volume-warning",
      "title": "NutsNews backend log volume warning",
      "severity": "warning",
      "service": "alloy",
      "datasource": "loki",
      "expr": "sum(count_over_time({host=\"backend.nutsnews.com\"}[1h]))",
      "threshold": 10000,
      "evaluator": "gt",
      "for": "15m",
      "range_seconds": 3600,
      "no_data_state": "OK",
      "summary": "Backend log volume is above the free-tier guardrail threshold."
    }
  ]
}
