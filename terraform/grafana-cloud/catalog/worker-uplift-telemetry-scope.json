  },
  "signalMatrix": [
    {
      "telemetryClass": "rabbitmq_metrics",
      "decision": "required",
      "destination": "grafana_cloud_metrics",
      "pipeline": "Alloy Prometheus scrape or exporter scrape on the backend host, then prometheus.remote_write.",
      "credentialSecrets": [
        "NUTSNEWS_GRAFANA_CLOUD_METRICS_URL",
        "NUTSNEWS_GRAFANA_CLOUD_METRICS_USERNAME",
        "NUTSNEWS_GRAFANA_CLOUD_ACCESS_POLICY_TOKEN"
      ],
      "rollbackSwitches": [
        "WORKER_TELEMETRY_METRICS_ENABLED=false",
        "enable_grafana_alloy=false"
      ]
    },
    {
      "telemetryClass": "worker_metrics",
      "decision": "required",
      "destination": "grafana_cloud_metrics",
      "pipeline": "Worker services expose Prometheus metrics on private listeners; Alloy scrapes and remote-writes them.",
      "credentialSecrets": [
        "NUTSNEWS_GRAFANA_CLOUD_METRICS_URL",
        "NUTSNEWS_GRAFANA_CLOUD_METRICS_USERNAME",
        "NUTSNEWS_GRAFANA_CLOUD_ACCESS_POLICY_TOKEN"
      ],
      "rollbackSwitches": [
        "WORKER_TELEMETRY_METRICS_ENABLED=false",
        "enable_grafana_alloy=false"
      ]
    },
    {
      "telemetryClass": "structured_logs",
      "decision": "required",
      "destination": "grafana_cloud_logs",
      "pipeline": "Service JSON logs and RabbitMQ service logs flow through Alloy loki.source, loki.process redaction, rate limits, buffering, and loki.write.",
      "credentialSecrets": [
        "NUTSNEWS_GRAFANA_CLOUD_LOGS_URL",
        "NUTSNEWS_GRAFANA_CLOUD_LOGS_USERNAME",
        "NUTSNEWS_GRAFANA_CLOUD_ACCESS_POLICY_TOKEN"
      ],
      "rollbackSwitches": [
        "WORKER_TELEMETRY_LOG_LEVEL=warn",
        "WORKER_TELEMETRY_LOGS_ENABLED=false",
        "enable_grafana_alloy=false"
      ]
    },
    {
      "telemetryClass": "traces",
      "decision": "deferred",
      "destination": "none",
      "pipeline": "No Grafana Cloud Tempo export, OTLP endpoint, or traces credential is provisioned by this policy.",
      "allowedInitialSampleRatio": 0,
      "futureMaximumInitialSampleRatio": 0.01,
      "futureEnablementRequirements": [
        "New reviewed infra PR",
        "Trace quota alerts green for seven consecutive days",
        "WORKER_TELEMETRY_TRACES_ENABLED=true",
        "WORKER_TELEMETRY_TRACE_SAMPLE_RATIO<=0.01",
        "traces:write credential scoped to the Grafana stack"
      ],
      "rollbackSwitches": [
        "WORKER_TELEMETRY_TRACES_ENABLED=false",
        "WORKER_TELEMETRY_TRACE_SAMPLE_RATIO=0"
      ]
    },
    {
      "telemetryClass": "exemplars",
      "decision": "deferred",
      "destination": "none",
      "pipeline": "No exemplars are exported until traces are explicitly approved.",
      "allowedInitialSampleRatio": 0,
      "rollbackSwitches": [
        "WORKER_TELEMETRY_EXEMPLARS_ENABLED=false"
      ]
    },
    {
      "telemetryClass": "profiles",
      "decision": "forbidden",
      "destination": "none",
      "pipeline": "No profiling signal is approved for worker uplift.",
      "rollbackSwitches": [
        "Do not provision a profiles write endpoint or credential."
      ]
    },
    {
      "telemetryClass": "article_or_model_payloads",
      "decision": "forbidden",
      "destination": "none",
      "pipeline": "Article bodies, summaries, model prompts, model outputs, credentials, and production token material must not be sent to metrics, logs, traces, or exemplars.",
      "rollbackSwitches": [
        "Disable the emitting service and treat payload leakage as a privacy incident."
      ]
    }
  ],
