{% set nutsnews_environment = vps_service_foundation_nutsnews_environments.production %}
{% if nutsnews_environment.staged_route_enabled | bool %}
handle {{ nutsnews_environment.route_path | regex_replace('/+$', '') }}{{ nutsnews_environment.health_path }} {
  # This private loopback route is a health-only gate, not proof that the app works under a path prefix.
  uri strip_prefix {{ nutsnews_environment.route_path | regex_replace('/+$', '') }}
  reverse_proxy {{ nutsnews_environment.network_alias }}:{{ nutsnews_environment.container_port }} {
    health_uri {{ nutsnews_environment.health_path | default('/healthz') }}
  }
}
{% else %}
# Production app route staging is currently disabled.
{% endif %}
