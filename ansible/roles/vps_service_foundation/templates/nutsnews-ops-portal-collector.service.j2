{% set nutsnews_environment = vps_service_foundation_nutsnews_environments.production %}
[Unit]
Description=NutsNews Operations Portal read-only data collector
Documentation={{ vps_service_foundation_docs_base_url }}
After=network-online.target docker.service
Wants=network-online.target
ConditionPathIsDirectory={{ vps_service_foundation_portal_data_dir }}

[Service]
Type=oneshot
User=root
Group=root
EnvironmentFile=-{{ vps_service_foundation_free_tier_env_file }}
Environment="NUTSNEWS_ROOT_DIR={{ vps_service_foundation_root }}"
Environment="NUTSNEWS_PORTAL_OUTPUT={{ vps_service_foundation_portal_status_file }}"
Environment="NUTSNEWS_BACKUPS_DIR={{ vps_service_foundation_backups_dir }}"
Environment="NUTSNEWS_PUBLIC_IPV4={{ vps_service_foundation_public_ipv4 }}"
Environment="NUTSNEWS_PUBLIC_IPV6={{ vps_service_foundation_public_ipv6 }}"
Environment="NUTSNEWS_DOCS_BASE_URL={{ vps_service_foundation_docs_base_url }}"
Environment="NUTSNEWS_INFRA_REPO_URL={{ vps_service_foundation_infra_repo_url }}"
Environment="NUTSNEWS_DEPLOYED_COMMIT_FILE={{ vps_service_foundation_deployed_infra_commit_file }}"
Environment="NUTSNEWS_APPLY_STATUS_FILE={{ vps_service_foundation_apply_status_file }}"
Environment="NUTSNEWS_APP_ENVIRONMENT={{ nutsnews_environment.name }}"
Environment="NUTSNEWS_APP_ENABLED={{ (nutsnews_environment.enabled | bool) | ternary('1', '0') }}"
Environment="NUTSNEWS_APP_STAGED_ROUTE_ENABLED={{ (nutsnews_environment.staged_route_enabled | bool) | ternary('1', '0') }}"
Environment="NUTSNEWS_APP_PUBLIC_ROUTE_ENABLED={{ (nutsnews_environment.public_route_enabled | bool) | ternary('1', '0') }}"
Environment="NUTSNEWS_APP_CONTAINER_NAME={{ nutsnews_environment.container_name }}"
Environment="NUTSNEWS_APP_CONTAINER_PORT={{ nutsnews_environment.container_port }}"
Environment="NUTSNEWS_APP_IMAGE={{ nutsnews_environment.image }}"
Environment="NUTSNEWS_APP_IMAGE_REPO={{ nutsnews_environment.image_repo }}"
Environment="NUTSNEWS_APP_IMAGE_DIGEST={{ nutsnews_environment.image_digest }}"
Environment="NUTSNEWS_APP_SOURCE_COMMIT={{ nutsnews_environment.source_commit }}"
Environment="NUTSNEWS_APP_BUILD_ID={{ nutsnews_environment.build_id }}"
Environment="NUTSNEWS_APP_DEPLOYMENT_TARGET={{ nutsnews_environment.deployment_target }}"
Environment="NUTSNEWS_APP_LAST_KNOWN_GOOD_DIGEST={{ nutsnews_environment.last_known_good_digest }}"
Environment="NUTSNEWS_APP_HEALTH_PATH={{ nutsnews_environment.health_path }}"
Environment="NUTSNEWS_APP_ROUTE_PATH={{ nutsnews_environment.route_path }}"
Environment="NUTSNEWS_APP_PUBLIC_DOMAIN={{ nutsnews_environment.public_domain }}"
Environment="NUTSNEWS_APP_APPLY_MARKER_FILE={{ nutsnews_environment.apply_marker_file }}"
Environment="NUTSNEWS_APP_ENV_FILE={{ nutsnews_environment.env_file }}"
Environment="NUTSNEWS_APP_SECRET_ENV_KEYS={{ nutsnews_environment.secret_env_keys | join(',') }}"
Environment="NUTSNEWS_APP_REQUIRED_SECRET_KEYS={{ nutsnews_environment.required_secrets | join(',') }}"
Environment="NUTSNEWS_REPORTING_STATUS_FILE={{ vps_service_foundation_reporting_status_file }}"
Environment="NUTSNEWS_BACKUP_STATUS_FILE={{ vps_service_foundation_backup_status_file }}"
Environment="NUTSNEWS_DOCKER_CLEANUP_STATUS_FILE={{ vps_service_foundation_docker_cleanup_status_file }}"
Environment="NUTSNEWS_COLLECTOR_TIMER_CADENCE_SECONDS={{ vps_service_foundation_collector_timer_cadence_seconds }}"
Environment="NUTSNEWS_COLLECTOR_SLOW_CACHE_FILE={{ vps_service_foundation_collector_slow_cache_file }}"
Environment="NUTSNEWS_COLLECTOR_DOCKER_INSPECT_CACHE_SECONDS={{ vps_service_foundation_collector_docker_inspect_cache_seconds }}"
Environment="NUTSNEWS_COLLECTOR_DOCKER_COMPOSE_CACHE_SECONDS={{ vps_service_foundation_collector_docker_compose_cache_seconds }}"
Environment="NUTSNEWS_COLLECTOR_PROCESSES_CACHE_SECONDS={{ vps_service_foundation_collector_processes_cache_seconds }}"
Environment="NUTSNEWS_COLLECTOR_LOGS_CACHE_SECONDS={{ vps_service_foundation_collector_logs_cache_seconds }}"
Environment="NUTSNEWS_COLLECTOR_SECURITY_CACHE_SECONDS={{ vps_service_foundation_collector_security_cache_seconds }}"
Environment="NUTSNEWS_COLLECTOR_BACKUPS_CACHE_SECONDS={{ vps_service_foundation_collector_backups_cache_seconds }}"
Environment="NUTSNEWS_COLLECTOR_FREE_TIER_LOCAL_CACHE_SECONDS={{ vps_service_foundation_collector_free_tier_local_cache_seconds }}"
Environment="NUTSNEWS_COLLECTOR_OOM_EVIDENCE_CACHE_SECONDS={{ vps_service_foundation_collector_oom_evidence_cache_seconds }}"
Environment="NUTSNEWS_COLLECTOR_OBSERVABILITY_CACHE_SECONDS={{ vps_service_foundation_collector_observability_cache_seconds }}"
Environment="NUTSNEWS_DISK_SCAN_CACHE_FILE={{ vps_service_foundation_disk_scan_cache_file }}"
Environment="NUTSNEWS_DISK_SCAN_CACHE_SECONDS={{ vps_service_foundation_disk_scan_cache_seconds }}"
Environment="NUTSNEWS_DISK_SCAN_ROOTS={{ vps_service_foundation_disk_scan_roots | join(',') }}"
Environment="NUTSNEWS_SWAP_USAGE_CACHE_FILE={{ vps_service_foundation_swap_usage_cache_file }}"
Environment="NUTSNEWS_SWAP_NON_TRIVIAL_BYTES={{ vps_service_foundation_swap_non_trivial_bytes }}"
Environment="NUTSNEWS_SWAP_WARNING_PERCENT={{ vps_service_foundation_swap_warning_percent }}"
Environment="NUTSNEWS_SWAP_CRITICAL_PERCENT={{ vps_service_foundation_swap_critical_percent }}"
Environment="NUTSNEWS_SWAP_SUSTAINED_SECONDS={{ vps_service_foundation_swap_sustained_seconds }}"
Environment="NUTSNEWS_OOM_EVIDENCE_WINDOW={{ vps_service_foundation_oom_evidence_window }}"
Environment="NUTSNEWS_ALLOY_ENABLED={{ vps_service_foundation_grafana_alloy_enabled | ternary('1', '0') }}"
Environment="NUTSNEWS_ALLOY_COLLECT_DOCKER={{ vps_service_foundation_grafana_alloy_collect_docker | ternary('1', '0') }}"
Environment="NUTSNEWS_ALLOY_COLLECT_DOCKER_LOGS={{ vps_service_foundation_grafana_alloy_collect_docker_logs | ternary('1', '0') }}"
Environment="NUTSNEWS_ALLOY_SERVICE=alloy.service"
Environment="NUTSNEWS_ALLOY_READY_URL={{ vps_service_foundation_grafana_alloy_ready_url }}"
Environment="NUTSNEWS_ALLOY_ERROR_WINDOW={{ vps_service_foundation_grafana_alloy_error_validation_since }}"
Environment="NUTSNEWS_ALLOY_TEXTFILE_DIR={{ vps_service_foundation_grafana_alloy_textfile_dir }}"
Environment="HOME=/tmp"
Environment="DOCKER_CONFIG=/tmp/docker"
Environment="XDG_CACHE_HOME=/tmp/cache"
ExecStart={{ vps_service_foundation_collector_bin }}
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=read-only
ProtectSystem=strict
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
LockPersonality=true
MemoryDenyWriteExecute=true
SystemCallArchitectures=native
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6 AF_NETLINK
ReadWritePaths={{ vps_service_foundation_portal_data_dir }} {{ vps_service_foundation_collector_log_dir }}

[Install]
WantedBy=multi-user.target
