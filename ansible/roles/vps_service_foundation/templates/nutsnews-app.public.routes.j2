{% if vps_service_foundation_nutsnews_app_public_route_enabled | bool %}
handle {
  # Caddy preserves the original Host and sets X-Forwarded-For by default.
  # Keep application response/security headers intact and stream responses.
  reverse_proxy {{ vps_service_foundation_nutsnews_app_container_name }}:{{ vps_service_foundation_nutsnews_app_container_port }} {
    header_up Host {host}
    header_up X-Forwarded-Host {host}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Real-IP {remote_host}
    flush_interval -1
    health_uri {{ vps_service_foundation_nutsnews_app_health_path | default('/healthz') }}
  }
}
{% else %}
# Public NutsNews app routing is intentionally disabled.
# Promotion requires a reviewed immutable digest and explicit GitOps flag change.
{% endif %}
